NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
CLERK_WEBHOOK_SECRET=whsec_...

# Optionnel mais recommandé si "failed_to_load_clerk_js" : origine du Frontend API Clerk
# (Dashboard Clerk → Configure → API / Domains → "Frontend API" → URL https://….clerk.accounts.dev)
# NEXT_PUBLIC_CLERK_PRECONNECT_ORIGIN=https://YOUR_INSTANCE.clerk.accounts.dev
# Alternative : NEXT_PUBLIC_CLERK_DOMAIN=YOUR_INSTANCE.clerk.accounts.dev
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# Supabase
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=

# Upstash Redis (for rate limiting)
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
# RATE_LIMIT_ENABLED=true

# Anti-abus LLM (généreux, par utilisateur ; nécessite Redis ci-dessus). Désactiver : ABUSE_RATE_LIMIT_ENABLED=false
# ABUSE_RATE_LIMIT_ENABLED=true
# RATE_LIMIT_ABUSE_RECOMMEND_MAX=120
# RATE_LIMIT_ABUSE_RECOMMEND_WINDOW_SEC=3600
# RATE_LIMIT_ABUSE_GUIDES_MAX=90
# RATE_LIMIT_ABUSE_GUIDES_WINDOW_SEC=3600

# Logs LLM verbeux : en prod, activer avec DEBUG_LLM=1 ; désactiver partout avec DEBUG_LLM=0
# DEBUG_LLM=
# LLM Providers
# CEREBRAS_API_KEY=  # Recommended — primary LLM (Qwen 3 235B → GPT-OSS 120B fallback)
# GROQ_API_KEY=      # Fallback LLM (Qwen 3 32B → Llama 3.3 70B fallback)
# GEMINI_API_KEY=    # Last resort fallback (Gemini 2.5 Flash-Lite)
# ANTHROPIC_API_KEY= # Optional — Claude (used if configured in llm/router)

# Embeddings
# JINA_API_KEY=          # Required — vector embeddings (Jina AI v3, 1024 dims)

# Logo.dev (for company logos)
NEXT_PUBLIC_LOGO_DEV_TOKEN=pk_aJ8Bl7ROS6-FE3fLWji9tQ

# Stripe (optional)
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# NEXT_PUBLIC_STRIPE_PRO_PRICE_ID=price_...
# NEXT_PUBLIC_STRIPE_AGENCY_PRICE_ID=price_...

# Sentry (monitoring & error tracking)
# NEXT_PUBLIC_SENTRY_DSN=https://xxx@oXXX.ingest.sentry.io/XXX
# SENTRY_ORG=your-org-slug
# SENTRY_PROJECT=your-project-slug
# SENTRY_AUTH_TOKEN=sntrys_xxx (for source maps upload in CI)
