# Supabase
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=

# Upstash Redis (for rate limiting)
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
# RATE_LIMIT_ENABLED=true

# LLM Providers
# CEREBRAS_API_KEY=  # Recommended — primary LLM (Llama 3.1 70B, ~2000 tokens/sec)
# GROQ_API_KEY=      # Fallback LLM (Llama 4 Scout / Llama 3.3 70B via Groq)
# GEMINI_API_KEY=    # Last resort fallback (Gemini Flash-Lite)
# ANTHROPIC_API_KEY= # Optional — Claude (used if configured in llm/router)

# Embeddings
# JINA_API_KEY=          # Required — vector embeddings (Jina AI v3, 1024 dims)

# Logo.dev (for company logos)
